SQL_AGENT_DB_URL=jdbc:mysql://mysql:3306/sql_agent_demo?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SQL_AGENT_DB_USERNAME=
SQL_AGENT_DB_PASSWORD=
SQL_AGENT_DB_DRIVER=com.mysql.cj.jdbc.Driver

SQL_AGENT_MODEL_BASE_URL=https://api.openai.com/v1
SQL_AGENT_MODEL_API_KEY=
SQL_AGENT_MODEL=gpt-4o-mini
SQL_AGENT_AVAILABLE_MODELS=gpt-4o-mini,gpt-4.1-mini,gpt-4.1,gpt-4o
SQL_AGENT_MODEL_TIMEOUT=60
SQL_AGENT_MODEL_TEMPERATURE=0.7
SQL_AGENT_MODEL_MAX_TOKENS=2000
SQL_AGENT_MODEL_LOG_REQUESTS=false
SQL_AGENT_MODEL_LOG_RESPONSES=false

SQL_AGENT_DEMO_READ_ONLY=true
SQL_AGENT_MUTATION_ENABLED=false

# 优化样例SQL（高度体现Agent能力的5个不同优化场景）
SQL_AGENT_SAMPLE_1_TITLE=时间函数改写+索引优化
SQL_AGENT_SAMPLE_1_DESC=演示日期函数包裹索引列导致失效，需要改写为范围查询并添加复合索引
SQL_AGENT_SAMPLE_1_SQL=SELECT * FROM user_behavior WHERE DATE_FORMAT(create_time, '%Y%m') = '202503' AND behavior_type NOT IN (1, 2);

SQL_AGENT_SAMPLE_2_TITLE=隐式类型转换+复合索引
SQL_AGENT_SAMPLE_2_DESC=演示bigint类型的user_id与字符串比较导致类型转换，需要修复类型匹配并添加索引
SQL_AGENT_SAMPLE_2_SQL=SELECT * FROM user_behavior WHERE DATE_FORMAT(create_time, '%Y%m') = '202503' AND behavior_type IN (1, 2, 3) AND user_id = '361';

SQL_AGENT_SAMPLE_3_TITLE=多表连接优化+覆盖索引
SQL_AGENT_SAMPLE_3_DESC=演示三表连接场景，优化连接顺序并创建覆盖索引避免回表
SQL_AGENT_SAMPLE_3_SQL=SELECT o.order_id, o.user_id, oi.product_id, p.product_name FROM orders o JOIN order_item oi ON o.order_id = oi.order_id JOIN product p ON oi.product_id = p.product_id WHERE o.status = 1 AND o.create_time >= '2025-03-01' AND o.create_time < '2025-04-01';

SQL_AGENT_SAMPLE_4_TITLE=OR条件改写+索引分离
SQL_AGENT_SAMPLE_4_DESC=演示OR条件导致索引失效，改写为UNION ALL分别利用不同索引
SQL_AGENT_SAMPLE_4_SQL=SELECT * FROM orders WHERE status = 1 OR create_time >= '2025-03-01';

SQL_AGENT_SAMPLE_5_TITLE=IN子查询优化+索引设计
SQL_AGENT_SAMPLE_5_DESC=演示IN子查询全表扫描，通过添加索引和改写SQL提升性能
SQL_AGENT_SAMPLE_5_SQL=SELECT * FROM product WHERE category_id IN (SELECT category_id FROM category WHERE parent_id = 10) AND status = 1;
